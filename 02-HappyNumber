class Solution {
    public boolean isHappy(int n) {
        int rem=0,squr=0;
        if(n<10){
            n=n*n;
        }

        while(n!=1 && n!=4){
            int sum=0;
            while(n>0){
                rem=n%10;
                squr=rem*rem;
                sum+=squr;
                n/=10;
            }
            n=sum;
        }
        return n==1;
    }
}
