class Solution {
    public String maximumOddBinaryNumber(String s) {

      /*  int n=s.length();
        int oneCnt=0;
        for(char ch:s.toCharArray()){
            if(ch=='1')oneCnt++;
        }

        StringBuilder sb=new StringBuilder();

        for(int i=0;i<oneCnt-1;i++){
            sb.append('1');
